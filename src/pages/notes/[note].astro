---
import MainLayout from "@layouts/MainLayout.astro";
import { getCollection, getEntry, render } from "astro:content";

const { note } = Astro.params;
const entry = await getEntry("notes", "dreams/" + note);
console.debug(note);
if (!entry) throw new Error("Could not find blog post 1");
const { Content } = await render(entry);

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes.map((note) => ({
    params: { note: note.data.name },
  }));
}

const wordCount = entry?.body?.split(/\s+/).length;
const readingTime = Math.ceil((wordCount ?? 0) / 200);
---

<MainLayout>
  <div class="article">
    <div class="content">
      <h1>{entry.data.title}</h1>
      <p class="time">
        ~ {readingTime} minute{readingTime > 1 ? "s" : ""} read
      </p>
      <Content />
      <a class="back" href={"/notes#" + entry.data.name}> ← back to notes </a>
    </div>
  </div>
</MainLayout>

<style>
  .article {
    justify-self: flex-start;
    display: flex;
    flex-flow: column;
    gap: 1rem;
    height: 100%;
    flex-grow: 1;
    display: grid;
    padding: 0;
    gap: 1.5rem;
    grid-template-columns: 18rem auto 18rem;
    padding-bottom: 4rem;

    @media screen and (max-width: 800px) {
      width: 100%;
      grid-template-columns: 1fr;
    }
  }

  .time {
    display: flex;
    padding-bottom: 1rem;
    color: var(--color-dim);
  }

  .content {
    grid-column: 2;
    max-width: 44rem;
    padding: 0 1rem 10rem;
    margin: 0 auto;

    h1 {
      font-size: 2.5rem;
      text-transform: capitalize;
    }
    h2 {
      font-size: 1.75rem;
      &:not(:first-child) {
        margin-top: 1.5rem;
        margin-bottom: 1rem;
      }
    }
    h3 {
      font-size: 1.25rem;
      &:not(:first-child) {
        margin-top: 1.25rem;
        margin-bottom: 1rem;
      }
    }
    h4 {
      font-size: 1.4rem;
      &:not(:first-child) {
        margin-top: 1rem;
        margin-bottom: 0.75rem;
      }
    }

    hr {
      margin: 2rem 0;
      color: var(--bg-light);
    }

    a {
      text-decoration: underline;
    }

    p:not(:first-child) {
      margin: 0.75rem 0;
    }

    p,
    li {
      font-family: "Apercu regular";
    }

    @media (max-width: 1280px) {
      grid-column: 1;
    }
  }

  .headings {
    position: sticky;
    top: 2rem;
    display: flex;
    flex-flow: column;
    height: calc(100dvh - 4rem);
    border-right: 2px solid var(--bg-darker0);

    nav {
      display: flex;
      flex-flow: column;
      color: var(--color-light);
      padding: 0;
      padding-bottom: 2rem;
      height: fit-content;
      overflow: hidden;
      border-radius: 0.25rem;

      a {
        display: flex;
        text-decoration: none;
        font-size: 0.9rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        gap: 0.5rem;
        letter-spacing: -0.5px;

        &:hover {
          text-decoration: underline;
          color: var(--color);
        }
      }
    }

    .h2 {
      margin-bottom: 0.15rem;
      &:not(:first-child) {
        margin-top: 1rem;
      }
    }

    .h3 {
      color: var(--color-light);
      font-family: "Apercu regular";
    }

    @media (max-width: 1280px) {
      position: relative;
      height: fit-content;
      width: fit-content;
      margin: 0 auto;
      top: 0;
      padding: 2rem 0;
      border: none;
    }
  }

  .back {
    font-size: 0.9rem;
    text-align: center;
    margin-top: 4rem;
    /* position: absolute;
    bottom: 0; */
    text-decoration: underline;
  }
</style>
