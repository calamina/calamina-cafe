---
import ArticleList from "@components/ArticleList.astro";
import { description } from "@data/description";
import MainLayout from "@layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const notes = await getCollection("notes");
const tidyNotes = Map.groupBy(notes, ({ id }) => id.split("/")[0])
    .values()
    .map((category) => ({
        id: category[0].id.split("/")[0],
        content: category.map((note) => note.data),
    }));

export async function getStaticPaths() {
    const notes = await getCollection("notes");
    return notes.map((note) => ({
        params: { note: note.data.name },
    }));
}
---

<MainLayout description={description.notes}>
    <div class="view">
        <div class="header">
            <h1>Notes</h1>
            <p>{description.notes}</p>
        </div>
        {
            tidyNotes.map((category) => (
                <ArticleList
                    entries={category.content}
                    url="notes"
                    listTitle={category.id}
                />
            ))
        }
    </div>
</MainLayout>

<style>
    .header {
        display: flex;
        flex-flow: column;
        gap: 0.25rem;
        width: fit-content;

        h1 {
            font-size: 3rem;
            letter-spacing: -2px;
            line-height: 3.5rem;
        }
    }

    .view {
        width: 100%;
        padding: 4rem 0;
        width: 50rem;
        margin: 0 auto;
        display: flex;
        flex-flow: column;
        gap: 3rem;

        @media (max-width: 1280px) {
            padding: 4rem 2rem;
            width: 100%;
        }
    }
</style>
