---
import CollectionLatest from "@components/CollectionLatest.astro";
import MainLayout from "@layouts/MainLayout.astro";
import { queryLastArticle, queryLastProject } from "@utils/utils";

const latestProject = await queryLastProject();
const latestArticle = await queryLastArticle();
---

<script>
  import { useAscii } from "@utils/ascii";
  useAscii();

  // const titles = ["Grégoire Belliere", "@calamina"];
  // const titles = ["creative", "frontend", "hesitant"];
  const states = ["unfinished", "human made"];
  let index = 0;

  // const title = document.querySelector(".title");
  const state = document.querySelector(".state");

  setInterval(() => {
    if (!state) return;
    index = (index + 1) % states.length;
    state.textContent = states[index];
  }, 3900);
  // if (!title || !state) return;
  // title.textContent = titles[index];
</script>

<MainLayout>
  <div id="container"></div>
  <h1>
    <span class="a">calamina</span>
    <span class="b">cafe</span>
  </h1>
  <div class="bottom">
    <div class="latest">
      <CollectionLatest
        name={latestArticle?.name}
        type="article"
        url="articles/"
      />
      <CollectionLatest
        name={latestProject?.name}
        type="project"
        url="projects/web/"
      />
    </div>
    <div class="description">
      <p>
        <span class="ball"></span>Personnal website of creative developper <span
          >Grégoire Belliere</span
        >
      </p>
      <p>Forever <span class="state">unfinished</span>, forever changing.</p>
    </div>
  </div>
</MainLayout>

<style>
  #container {
    position: fixed;
    z-index: -1;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100dvh;
  }

  h1 {
    font-size: 3.5rem;
    font-size: 13rem;
    font-family: "Redaction", serif;
    /* font-family: "Foss", serif; */
    /* font-family: "Grotesk", serif; */
    font-weight: 500;
    letter-spacing: -10px;
    /* max-width: calc(var(--app-width) - 5rem); */
    /* overflow-x: hidden; */
    /* font-style: italic; */
    /* font-variant: small-caps; */
    line-height: 9rem;
    display: grid;
    place-items: center;
    text-align: center;
    text-align: end;
    margin-bottom: 8rem;
    /* text-transform: capitalize; */
    /* text-transform: uppercase; */
  }

  h1 {
    display: flex;
    flex-flow: column;
    grid-template-columns: 1fr auto;
    width: fit-content;
    margin: 0 auto 8rem;
    gap: 0 2rem;
    align-items: end;

    span {
      font-size: 13rem;
      font-family: "Redaction", serif;
      font-weight: 500;
      letter-spacing: -10px;
      line-height: 9rem;
      display: grid;
      text-align: center;
      text-align: end;
      /* font-family: "Foss", serif; */
      /* font-family: "Grotesk", serif; */
      /* text-transform: capitalize; */
      /* text-transform: uppercase; */
      /* font-style: italic; */
      /* font-variant: small-caps; */

      @media (max-width: 50rem) {
        font-size: 7rem;
        letter-spacing: -4px;
        letter-spacing: -4px;
        line-height: 5.5rem;
      }
    }
  }

  .bottom {
    position: absolute;
    bottom: 4rem;
    left: 4rem;
    right: 4rem;
    display: flex;
    align-items: end;
    justify-content: space-between;
  }

  .latest {
    display: flex;
    flex-flow: column;
    gap: 0.75rem;
  }

  .description {
    display: flex;
    flex-flow: column;
    align-items: end;
    text-wrap: balance;
    padding: 0;
    border-radius: 0.4rem;

    p {
      background-color: var(--bg);
      /* background-color: var(--bg-darker0); */
      font-variant: all-small-caps;
      font-size: 1.05rem;
      line-height: 1.2rem;
      color: var(--color-light);

      &:first-of-type {
        display: inline-flex;
        gap: 0.5rem;
        align-items: center;

        .ball {
          background-color: var(--highlight);
          height: 0.45rem;
          width: 0.45rem;
          flex-shrink: 0;
          border-radius: 0.5rem;
        }
      }
    }
  }

  @media (max-width: 50rem) {
    .bottom {
      left: 3rem;
      right: 3rem;
      bottom: 2rem;
      display: flex;
      flex-flow: column;
      align-items: start;
      gap: 6rem;
    }

    .description {
      margin-left: auto;

      p,
      span {
        line-height: 0.9rem;
        letter-spacing: -0.5px;
        font-size: 0.8rem;
      }
    }
  }

  .state {
    display: inline-block;
    width: 8.5ch;
  }
</style>
