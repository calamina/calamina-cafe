---
import CollectionLatest from "@components/CollectionLatest.astro";
import MainLayout from "@layouts/MainLayout.astro";
import { queryLastArticle, queryLastProject } from "@utils/utils";
// import IntroCard from "@components/IntroCard.astro";

const latestProject = await queryLastProject();
const latestArticle = await queryLastArticle();
---

<script>
  import { useAscii } from "@utils/ascii";
  useAscii();

  // const titles = ["Grégoire Belliere", "@calamina"];
  // const titles = ["creative", "frontend", "hesitant"];
  const states = ["unfinished", "human made"];
  let index = 0;

  // const title = document.querySelector(".title");
  const state = document.querySelector(".state");

  setInterval(() => {
    if (!state) return;
    index = (index + 1) % states.length;
    state.textContent = states[index];
  }, 3900);
  // if (!title || !state) return;
  // title.textContent = titles[index];
</script>

<MainLayout>
  <div id="container"></div>
  <!-- <IntroCard /> -->
  <div class="hero">
    <h1>
      <span class="a">calamina</span>
      <span class="b">cafe</span>
      <!-- <span class="c">~</span> -->
    </h1>
  </div>
  <!-- <h1>calamina<br />cafe</h1> -->
  <!-- <h1 class="sec">calamina<br />cafe</h1> -->
  <p class="description">
    Personnal website of creative developper
    <!-- <span class="title">creative</span> -->
    <span>Grégoire Belliere</span><br />
    Forever <span class="state">unfinished</span>, forever changing.
  </p>
  <div class="latest">
    <CollectionLatest
      name={latestArticle?.name}
      type="article"
      url="articles/"
    />
    <CollectionLatest
      name={latestProject?.name}
      type="project"
      url="projects/web/"
    />
  </div>
</MainLayout>

<style>
  #container {
    position: fixed;
    z-index: -1;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100dvh;
  }

  h1 {
    font-size: 3.5rem;
    font-size: 13rem;
    font-family: "Redaction", serif;
    /* font-family: "Foss", serif; */
    /* font-family: "Grotesk", serif; */
    font-weight: 500;
    letter-spacing: -10px;
    /* font-style: italic; */
    /* font-variant: small-caps; */
    line-height: 9rem;
    display: grid;
    place-items: center;
    text-align: center;
    text-align: end;
    margin-bottom: 8rem;
    /* text-transform: capitalize; */
    /* text-transform: uppercase; */
  }

  h1 {
    display: grid;
    place-items: center;
    grid-template-columns: 1fr auto;
    width: fit-content;
    margin: 0 auto 8rem;
    gap: 0 2rem;
    grid-template-areas:
      "a a"
      "c b";

    span {
      &.a {
        grid-area: a;
        align-self: end;
      }
      &.b {
        grid-area: b;
        width: fit-content;
      }
      &.c {
        grid-area: c;
        justify-self: end;
        width: 100%;
        display: inline-block;
        color: var(--highlight);
        /* color: var(--color-light); */
        filter: blur(8px);
        letter-spacing: 1rem;
      }

      font-size: 3.5rem;
      font-size: 13rem;
      font-family: "Redaction", serif;
      /* font-family: "Foss", serif; */
      /* font-family: "Grotesk", serif; */
      font-weight: 500;
      letter-spacing: -10px;
      /* font-style: italic; */
      /* font-variant: small-caps; */
      line-height: 9rem;
      display: grid;
      place-items: center;
      text-align: center;
      text-align: end;
      /* text-transform: capitalize; */
      /* text-transform: uppercase; */
    }
  }

  .sec {
    font-family: "Foss", serif;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .latest {
    position: absolute;
    bottom: 4rem;
    left: 4rem;
    display: flex;
    flex-flow: column;
    gap: 0.75rem;
  }

  .description {
    position: absolute;
    text-wrap: balance;
    bottom: 4rem;
    right: 4rem;
    font-variant: all-small-caps;
    font-size: 1.05rem;
    line-height: 1.2rem;
    padding: 0.15rem 0.1rem 0 0.15rem;
    color: var(--color-light);
    background-color: var(--bg);
    border-radius: 0.4rem;

    &::before {
      padding: 0;
      margin: 0;
      content: "◆";
      content: "◈";
      color: var(--highlight);
      font-size: 0.8rem;
    }
  }

  .state {
    display: inline-block;
    width: 8.5ch;
  }
</style>
