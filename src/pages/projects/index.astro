---
import ProjectPreview from "@components/features/project/ProjectPreview.astro";
import { description } from "@data/description";
import MainLayout from "@layouts/MainLayout.astro";
import type { Project } from "@models/Project";
import { queryProjects } from "@utils/content.ts";

const projects: Project[] = await queryProjects();

const sort = (a: Project, b: Project) =>
    a.name.localeCompare(b.name, "en", { sensitivity: "base" });

const tags: Set<string> = new Set();
projects.map((project) => project.tags?.forEach((tag) => tags.add(tag)));

const countTags = (tagname: string) => {
    return projects.filter((project) =>
        project.tags?.some((tag) => tag === tagname),
    ).length;
};
---

<script>
    import { useProjectFilters } from "@utils/projects-filters";
    useProjectFilters();
</script>

<MainLayout description={description.projects}>
    <div class="container">
        <div class="header">
            <h1>Projects</h1>
            <p>{description.projects}</p>
        </div>
        <div class="intro">
            <div class="title">
                <h1>Web projects</h1>
                <span class="limit" inert></span>
                <p class="entries">
                    <span inert>(</span>
                    {projects.length} entr{projects.length > 1 ? "ies" : "y"}
                    <span inert>)</span>
                </p>
            </div>
            <p>Collection of small personnal web projects.</p>
            <nav>
                {
                    tags.values().map((tag) => (
                        <button class="tagSelector" value={tag}>
                            {tag}
                            <span class="count">{countTags(tag)}</span>
                        </button>
                    ))
                }
                <button class="reset">all</button>
            </nav>
        </div>
        <div class="projects" id="projects">
            {
                projects
                    .sort((a, b) => sort(a, b))
                    .map((project) => <ProjectPreview project={project} />)
            }
        </div>
    </div>
</MainLayout>

<style>
    .header {
        display: flex;
        flex-flow: column;
        gap: 0.25rem;
        width: fit-content;

        h1 {
            font-size: 3rem;
            letter-spacing: -2px;
            line-height: 3.5rem;
        }
    }

    .container {
        width: 60rem;
        margin: 0 auto;
        padding: 4rem 4rem 8rem;
        display: flex;
        flex-flow: column;
        gap: 3rem;

        @media (max-width: 1280px) {
            padding: 2rem;
            width: 100%;
        }
    }

    .intro {
        display: flex;
        flex-flow: column;
        gap: 0.25rem;
    }

    .title {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        justify-content: space-between;
    }

    .limit {
        height: 100%;
        border-bottom: 2px solid var(--bg-alter);
        display: flex;
        flex: 1;
    }

    .entries,
    .entries span {
        color: var(--color-alter);
    }

    nav {
        padding-top: 1rem;
        display: flex;
        gap: 1rem;

        @media (max-width: 1280px) {
            flex-flow: row wrap;
        }
    }

    button {
        display: flex;
        align-items: baseline;
        gap: 1ch;
        padding: 0 0.5rem 0.15rem 0.4rem;
        border-top-left-radius: 0.5rem;
        border-bottom-right-radius: 0.5rem;
        background-color: var(--bg-alt);

        @media (max-width: 1280px) {
            width: fit-content;
        }

        &:hover {
            background-color: var(--bg-alter);
        }

        &.reset {
            margin-left: auto;
            background-color: var(--bg-alt);

            @media (max-width: 1280px) {
                margin-left: 0;
            }
        }

        &.active,
        &:hover.active {
            background-color: var(--highlight);
        }

        &:hover,
        &.active {
            .count {
                color: var(--color-alt);
            }
        }
    }

    .count {
        color: var(--color-alter);
        font-size: 0.8rem;
    }

    .projects {
        position: relative;
        width: 100%;
        gap: 1.75rem 3rem;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        place-items: center;

        @media (max-width: 1280px) {
            grid-template-columns: 1fr 1fr;
            gap: 2rem 3rem;
        }
    }
</style>
