---
import ProjectFilters from "@components/features/project/ProjectFilters.astro";
import ProjectPreview from "@components/features/project/ProjectPreview.astro";
import { description } from "@data/description";
import PageLayout from "@layouts/PageLayout.astro";
import type { Project } from "@models/Project";
import { queryProjects } from "@utils/content.ts";

const projects: Project[] = await queryProjects();

const sort = (a: Project, b: Project) =>
    a.name.localeCompare(b.name, "en", { sensitivity: "base" });
---

<PageLayout title="Projects" description={description.projects}>
    <div class="content">
        <div class="intro">
            <div class="title">
                <h2>Web projects</h2>
                <span class="limit" inert></span>
                <p class="entries">
                    <span inert>(</span>
                    {projects.length} entr{projects.length > 1 ? "ies" : "y"}
                    <span inert>)</span>
                </p>
            </div>
            <p>Collection of small personnal web projects.</p>
            <ProjectFilters projects={projects} />
            <!-- <nav>
                {
                    tags.values().map((tag) => (
                        <button class="tagSelector" value={tag}>
                            {tag}
                            <span class="count">{countTags(tag)}</span>
                        </button>
                    ))
                }
                <button class="reset">all</button>
            </nav> -->
        </div>
        <div class="projects" id="projects">
            {
                projects
                    .sort((a, b) => sort(a, b))
                    .map((project) => <ProjectPreview project={project} />)
            }
        </div>
    </div>
</PageLayout>

<style>
    .content {
        display: flex;
        flex-flow: column;
        gap: 2rem;
    }

    .intro {
        display: flex;
        flex-flow: column;
        gap: 0.25rem;
    }

    .title {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        justify-content: space-between;
    }

    .limit {
        height: 100%;
        border-bottom: 2px solid var(--bg-alter);
        display: flex;
        flex: 1;
    }

    .entries,
    .entries span {
        color: var(--color-alter);
    }

    .projects {
        position: relative;
        width: 100%;
        gap: 1.75rem 3rem;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        place-items: center;

        @media (max-width: 1280px) {
            grid-template-columns: 1fr 1fr;
            gap: 2rem 3rem;
        }
    }
</style>
