---
import ProjectGallery from "@components/features/project/ProjectGallery.astro";
import ProjectInfo from "@components/features/project/ProjectInfo.astro";
import { queryProject } from "@utils/content.ts";
import MainLayout from "./MainLayout.astro";

interface Props {
  project: string;
}
const { project } = Astro.props;

const {
  name = "",
  tech,
  description = [],
  url,
} = (await queryProject(project)) ?? {};
---

<MainLayout description={description.join(" ")}>
  <div class="project">
    <ProjectInfo name={name} tech={tech} description={description} url={url} />
    <ProjectGallery project={project} name={name} />
    <a class="back" href={"/projects#" + name}>← back to projects</a>
  </div>
</MainLayout>

<style>
  .project {
    display: grid;
    grid-template-columns: repeat(12, minmax(0px, 1fr));
    gap: 0.5rem;
    width: 100%;

    @media (max-width: 1280px) {
      display: flex;
      flex-flow: column;
      padding: 0 0.5rem;
    }
  }

  .back {
    display: none;
    margin-top: auto;
    text-align: center;
    text-decoration: underline;
    margin-bottom: 2rem;

    @media (max-width: 1280px) {
      margin-top: 5rem;
      margin-bottom: 5rem;
      font-size: 1.8rem;
      color: var(--color-alter);
      width: 100%;
      display: flex;
      justify-content: center;
    }
  }
</style>
