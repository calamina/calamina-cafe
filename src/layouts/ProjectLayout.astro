---
import ButtonImage from "@components/ButtonImage.astro";
import ProjectGallery from "@components/features/project/ProjectGallery.vue";
import ProjectInfo from "@components/features/project/ProjectInfo.astro";
import MainLayoutFooterless from "@layouts/MainLayoutFooterless.astro";
import { queryProject } from "@utils/content.ts";
import { ProjectType } from "@utils/enum";
import { getProjectImages, isVerticalImage } from "@utils/images";
import { Image } from "astro:assets";

export interface Props {
  project: string;
  type: ProjectType;
}
const { project, type } = Astro.props;

const { name, tech, description, homepage } = (await queryProject(project)) ?? {
  name: "",
  description: [],
};

const images = getProjectImages(type, project);
---

<MainLayoutFooterless>
  <div class="project">
    <ProjectInfo
      name={name}
      url={homepage}
      tech={tech}
      description={description}
    />
    <ProjectGallery type={type} client:only>
      {
        images.map((image, index) =>
          image.then((img) => (
            <ButtonImage>
              <Image
                src={image}
                alt={`${name} gallery picture ${index + 1}`}
                loading={"eager"}
                class:list={[{ mobile: isVerticalImage(img) }]}
              />
            </ButtonImage>
          )),
        )
      }
    </ProjectGallery>
    <a class="back" href={"/projects#" + name}>← back to projects</a>
  </div>
</MainLayoutFooterless>

<style scoped>
  .project {
    display: grid;
    grid-template-columns: repeat(10, minmax(0px, 1fr));
    gap: 0.5rem;
    width: 100%;
  }

  img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  img.mobile {
    width: auto;
    height: 100%;
    max-height: 85dvh;
  }

  .back {
    display: none;
    margin-top: auto;
    text-align: center;
    text-decoration: underline;
    margin-bottom: 2rem;
  }

  @media (max-width: 1280px) {
    .back {
      display: flex;
    }

    .project {
      display: flex;
      flex-flow: column;
      padding: 0 0.5rem;
    }
  }
</style>
