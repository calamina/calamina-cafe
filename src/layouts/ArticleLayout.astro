---
import { getEntry, render } from "astro:content";
import MainLayout from "./MainLayout.astro";

interface Props {
  name: string;
  type: "articles" | "notes";
  displayToc?: boolean;
}
const { name, type, displayToc = true } = Astro.props;

const entry = await getEntry(type, name);
if (!entry) throw new Error(`Could not find ${type} ${name}`);
const { Content, headings } = await render(entry);

const filteredHeadings = headings.filter(
  (heading) => heading.depth > 1 && heading.depth < 4,
);

const wordCount = entry?.body?.split(/\s+/).length;
const readingTime = Math.ceil((wordCount ?? 0) / 200);
---

<MainLayout>
  <div class="article">
    {
      displayToc && (
        <div class="headings">
          <nav>
            <div class="h1">
              <a href={"#" + entry.data.name}>{entry.data.title}</a>
            </div>
            {filteredHeadings.map((heading) => (
              <div class={heading.depth === 2 ? "h2" : "h3"}>
                <a href={"#" + heading.slug}>{heading.text}</a>
              </div>
            ))}
          </nav>
          <a class="back" href={`/${type}#${entry.data.name}`}>
            ← back to {type}
          </a>
        </div>
      )
    }
    <div class="content">
      <h1 id={entry.data.name}>{entry.data.title}</h1>
      <p class="time">
        ~ {readingTime} minute{readingTime > 1 ? "s" : ""} read
      </p>
      <Content />
      {
        !displayToc && (
          <a class="back end" href={`/${type}#${entry.data.name}`}>
            ← back to {type}
          </a>
        )
      }
    </div>
  </div>
</MainLayout>

<style>
  .article {
    justify-self: flex-start;
    display: flex;
    flex-flow: column;
    gap: 1rem;
    height: 100%;
    flex-grow: 1;
    display: grid;
    padding: 0;
    gap: 1.5rem;
    grid-template-columns: 18rem auto 18rem;
    padding-bottom: 4rem;

    @media screen and (max-width: 800px) {
      width: 100%;
      grid-template-columns: 1fr;
    }
  }

  .content {
    grid-column: 2;
    max-width: 44rem;
    padding: 4rem 1rem 10rem;
    margin: 0 auto;

    h1 {
      font-size: 3rem;
      text-align: center;
      letter-spacing: -0.5px;
    }
    h2 {
      font-size: 2rem;
      line-height: 2.4rem;

      &:not(:first-child) {
        margin-top: 3rem;
        margin-bottom: 0.5rem;
      }
    }
    h3 {
      font-size: 1.5rem;
      &:not(:first-child) {
        margin-top: 2rem;
        margin-bottom: 0.5rem;
      }
    }
    h4 {
      font-size: 1.25rem;
      &:not(:first-child) {
        margin-top: 1rem;
        margin-bottom: 0.75rem;
      }
    }

    hr {
      margin: 2rem 0;
      color: transparent;
      border-top: 1px solid var(--bg-darker);
    }

    a {
      text-decoration: underline;
    }

    p:not(:first-child) {
      margin: 0.75rem 0;
    }

    p,
    li,
    span {
      font-family: "Apercu regular";
    }

    ul,
    ol {
      padding-left: 2ch;
    }

    ul {
      list-style-type: square;
    }

    sup {
      font-size: 0.7rem;
      font-family: "Apercu";
      color: var(--color-dim);

      &::before,
      &::after {
        font-size: 0.7rem;
      }
      &::before {
        content: "[";
      }
      &::after {
        content: "]";
      }
    }

    .info {
      font-size: 0.9rem;
      background-color: var(--bg-darker0);
      color: var(--color-dim);

      a {
        font-size: 0.9rem;
        padding: 0;
        color: var(--color-dim);

        &:hover,
        &:focus-visible {
          color: var(--color);
          background-color: transparent;
        }

        &:after {
          display: none;
        }
      }
    }

    p {
      line-height: 1.65rem;

      &:not(:first-of-type) {
        padding-top: 0.5rem;
      }
      &:not(:last-of-type) {
        padding-bottom: 0.5rem;
      }

      &:has(+ ul),
      &:has(+ ol) {
        padding-bottom: 0;
      }
    }

    a {
      position: relative;
      padding-right: 1.5ch;
      text-decoration: underline;

      &:after {
        position: absolute;
        right: 0;
        display: inline-block;
        content: " ->";
      }
    }

    p.time {
      display: flex;
      color: var(--color-dim);
      justify-content: center;
      width: fit-content;
      padding: 0 1rem 0.15rem;
      background-color: var(--bg-darker0);
      margin: 0.75rem auto 2.5rem;
      border-radius: 0.25rem;
    }

    ul,
    ol {
      display: flex;
      flex-flow: column;
      gap: 0.5rem;
    }

    li {
      line-height: 1.2rem;
    }

    @media (max-width: 1280px) {
      grid-column: 1;
    }
  }

  .headings {
    position: sticky;
    top: 5rem;
    display: flex;
    flex-flow: column;
    display: grid;
    grid-template-rows: 1fr 2rem;
    align-items: center;
    height: calc(100dvh - 7rem);
    /* padding: 2rem 0; */
    border-right: 2px solid var(--bg-darker0);

    nav {
      display: flex;
      flex-flow: column;
      color: var(--color-light);
      padding: 0 1rem 2rem 0;
      gap: 0.15rem;
      padding-bottom: 2rem;
      height: fit-content;
      overflow: hidden;
      border-radius: 0.25rem;

      a {
        display: flex;
        text-decoration: none;
        font-size: 0.9rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        gap: 0.5rem;
        letter-spacing: -0.5px;

        &:hover {
          text-decoration: underline;
          color: var(--color);
        }
      }
    }

    .h1,
    .h2,
    .h3 {
      a:focus-visible,
      a:hover {
        background-color: var(--highlight);
        outline: none;
        color: var(--color);
        text-decoration: underline;
      }
    }

    .h1 {
      margin-bottom: 0.25rem;
    }

    .h2,
    .h3 {
      padding-left: 3ch;
      position: relative;

      a {
        width: 100%;
        color: var(--color-dim);
        font-family: "Apercu Regular";
        transition: color 0.08s ease-out;
        line-height: 1.6rem;
      }

      &:before {
        position: absolute;
        left: 0;
        color: var(--color-light);
        font-weight: 100;
        background-color: transparent;
        opacity: 0.5;
      }
    }

    .h2 {
      &::before {
        content: "├─";
      }
      &:last-of-type:not(:has(+ .h3))::before {
        content: "╰─";
      }
    }

    .h3 {
      font-family: "Apercu regular";
      padding-left: 5ch;
      &::before {
        content: "├───";
      }
      &:last-of-type:not(:has(+ .h2))::before {
        content: "╰───";
      }
    }

    @media (max-width: 1280px) {
      position: relative;
      height: fit-content;
      width: fit-content;
      margin: 0 auto;
      top: 0;
      padding: 2rem 0;
      border: none;
    }
  }

  .back {
    font-size: 0.9rem;
    text-align: center;
    text-decoration: underline;

    &.end {
      margin-top: 4rem;
      padding-right: 0;

      &::after {
        display: none;
      }
    }
  }
</style>
