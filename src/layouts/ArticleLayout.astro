---
import { getEntry, render } from "astro:content";
import MainLayout from "./MainLayout.astro";

interface Props {
  name: string;
  type: "articles" | "notes";
  displayToc?: boolean;
  fullname?: string;
}
const { name, type, fullname, displayToc = true } = Astro.props;

const entry = await getEntry(type, fullname ?? name);
if (!entry) throw new Error(`Could not find ${type} ${name}`);
const { Content, headings } = await render(entry);

const filteredHeadings = headings.filter(
  (heading) => heading.depth > 1 && heading.depth < 4,
);

const wordCount = entry?.body?.split(/\s+/).length;
const readingTime = Math.ceil((wordCount ?? 0) / 200);
---

<MainLayout>
  <div class="article">
    {
      displayToc && (
        <div class="headings">
          <nav>
            <div class="h1">
              <a href={"#" + entry.data.name}>{entry.data.title}</a>
            </div>
            {filteredHeadings.map((heading) => (
              <div class={heading.depth === 2 ? "h2" : "h3"}>
                <a href={"#" + heading.slug}>{heading.text}</a>
              </div>
            ))}
          </nav>
          <a class="back" href={`/${type}#${entry.data.name}`}>
            ← back to {type}
          </a>
        </div>
      )
    }
    <div class="content">
      <h1 id={entry.data.name}>{entry.data.title}</h1>
      <p class="time">
        ~ {readingTime} minute{readingTime > 1 ? "s" : ""} read
      </p>
      <Content />
      {
        !displayToc && (
          <a class="back end" href={`/${type}#${entry.data.name}`}>
            ← back to {type}
          </a>
        )
      }
    </div>
  </div>
</MainLayout>

<style>
  @import url("../assets/style/pages/content.css");

  .article {
    justify-self: flex-start;
    display: flex;
    flex-flow: column;
    gap: 1rem;
    height: 100%;
    flex-grow: 1;
    display: grid;
    padding: 0;
    gap: 1.5rem;
    grid-template-columns: 18rem auto 18rem;
    padding-bottom: 4rem;

    @media screen and (max-width: 1280px) {
      width: 100%;
      display: flex;
      flex-flow: column;
      padding-bottom: 2rem;
    }
  }

  .headings {
    position: sticky;
    top: 5rem;
    display: flex;
    flex-flow: column;
    display: grid;
    grid-template-rows: 1fr 2rem;
    align-items: center;
    height: calc(100dvh - 9rem);
    border-right: 2px solid var(--bg-alt);
    /* height: calc(100dvh - 7rem); */

    nav {
      display: flex;
      flex-flow: column;
      color: var(--color-alter);
      padding: 0 1rem 2rem 0;
      gap: 0.15rem;
      padding-bottom: 2rem;
      height: fit-content;
      overflow: hidden;

      a {
        display: block;
        text-decoration: none;
        font-size: 0.85rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        gap: 0.5rem;
        letter-spacing: -0.5px;
        max-width: 100%;

        &:hover {
          text-decoration: underline;
          color: var(--color);
        }
      }
    }

    .h1,
    .h2,
    .h3 {
      overflow: hidden;

      a:focus-visible,
      a:hover {
        background-color: var(--highlight);
        outline: none;
        color: var(--color);
        text-decoration: underline;
      }
    }

    .h1 {
      margin-bottom: 0.25rem;
    }

    .h2,
    .h3 {
      padding-left: 2ch;
      position: relative;

      a {
        padding-left: 1ch;
        width: 100%;
        color: var(--color-alt);
        font-weight: 300;
        transition: color var(--timing-xs);
        line-height: 1.3rem;
      }

      &:before {
        position: absolute;
        left: 0;
        color: var(--color-alter);
        font-weight: 100;
        line-height: 1.3rem;
        background-color: transparent;
        opacity: 0.5;
      }
    }

    .h2 {
      &::before {
        content: "├─";
      }
      &:last-of-type:not(:has(+ .h3))::before {
        content: "╰─";
      }
    }

    .h3 {
      font-weight: 300;
      padding-left: 4ch;
      &::before {
        content: "├───";
      }
      &:last-of-type:not(:has(+ .h2))::before {
        content: "╰───";
      }
    }

    @media (max-width: 1280px) {
      display: none;
      position: relative;
      height: fit-content;
      width: fit-content;
      margin: 0 auto;
      top: 0;
      padding: 2rem 0;
      border: none;
    }
  }

  .back {
    font-size: 0.9rem;
    text-align: center;
    text-decoration: underline;

    &.end {
      margin-top: 4rem;
      padding-right: 0;

      &::after {
        display: none;
      }
    }

    @media (max-width: 1280px) {
      display: none;
    }
  }
</style>
