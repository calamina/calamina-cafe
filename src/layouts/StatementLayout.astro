---
import MainLayout from "./MainLayout.astro";

interface Props {
  description?: string | undefined;
}

const { description } = Astro.props;
---

<MainLayout description={description}>
  <div>
    <slot />
  </div>
</MainLayout>

<style>
  div {
    padding: 0;
    margin: 0;
    display: flex;
    flex-flow: column;
    gap: 1.5rem;
    width: 100%;
    max-width: 50rem;
    margin: 0 auto;
  }
</style>
