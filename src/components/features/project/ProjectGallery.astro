---
import { getProjectImages } from "@utils/images";
import { Image } from "astro:assets";

interface Props {
  project: string;
  name: string;
}

const { project, name } = Astro.props;
const images = getProjectImages(project);
---

<div class="wrapper">
  <div class="gallery">
    {
      images.map((image, index) => (
        <div class="imgwrap">
          <Image src={image} alt={`${name} ${index + 1}`} loading="eager" />
        </div>
      ))
    }
  </div>
</div>

<style scoped>
  .wrapper {
    display: flex;
    flex-flow: column;
    gap: 0.5rem;
    width: 100%;
    padding-bottom: 1.5rem;
    grid-column-start: 6;
    grid-column-end: 13;
  }

  .gallery {
    display: grid;
    gap: 0.5rem;
    padding-top: 0;
    grid-template-columns: 1fr;
    display: flex;
    flex-flow: column;
    /* display: grid;
    grid-template-columns: repeat(2, minmax(0px, 1fr)); */
  }

  .imgwrap {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 100%;
    /* background-color: var(--bg-darker0); */
    padding: 2rem;
    background-color: var(--bg-light);
    /* background-color: var(--color); */
    border-radius: 0.25rem;
    max-height: 70vh;

    &:first-of-type {
      grid-column: span 2;
    }
  }

  img {
    border-radius: 0.25rem;
    width: auto;
    height: 100%;
    /* object-fit: cover; */
  }

  @media (max-width: 1280px) {
    .wrapper {
      padding-bottom: 0;
      flex: 1;
    }

    .gallery {
      display: flex;
      flex-flow: column;
      padding-top: 0rem;
    }
  }
</style>
