---
import { getProjectImages } from "@utils/images";
import { Image } from "astro:assets";

interface Props {
  project: string;
  name: string;
}

const { project, name } = Astro.props;
const images = getProjectImages(project);
---

<div class="wrapper">
  <div class="gallery">
    {
      images.map((image, index) => (
        <div class="imgwrap">
          <Image src={image} alt={`${name} ${index + 1}`} loading="eager" />
        </div>
      ))
    }
  </div>
</div>

<style>
  .wrapper {
    display: flex;
    flex-flow: column;
    gap: 0.5rem;
    width: 100%;
    padding-bottom: 1.5rem;
    grid-column-start: 5;
    grid-column-end: 13;
  }

  .gallery {
    display: grid;
    gap: 0.5rem;
    padding-top: 0;
    grid-template-columns: 1fr;
    display: flex;
    flex-flow: column;
  }

  .imgwrap {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 100%;
    background-color: var(--bg-alt);
    border-radius: var(--radius-sm);
    max-height: 70vh;

    &:first-of-type {
      grid-column: span 2;
    }

    @media (max-width: 1280px) {
      max-height: unset;
    }
  }

  img {
    border-radius: var(--radius-sm);
    width: 100%;
    height: auto;
    max-height: 100%;

    /* object-fit: cover; */
    object-fit: contain;
  }

  @media (max-width: 1280px) {
    .wrapper {
      padding-bottom: 0;
      flex: 1;
    }

    .gallery {
      display: flex;
      flex-flow: column;
      padding-top: 0rem;
    }
  }
</style>
