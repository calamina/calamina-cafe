---
import type { Project } from "@models/Project";
import { getImage } from "@utils/images";
import { Image } from "astro:assets";

export interface Props {
  project: Project;
}

const { project } = Astro.props;
const url = "/projects/";
const image = await getImage(project.name);
---

<a
  class="project"
  class:list={project.tags}
  id={project.name}
  href={url + project.name}
>
  <Image src={image.default} alt=`${project.name} cover` loading="eager" />
  <p class="project-name">{project.name}</p>
</a>

<style>
  .project {
    position: relative;
    display: flex;
    flex-flow: column;
    gap: 0.15rem;
    outline: none;
    width: 100%;
    background-color: transparent;
    transition:
      opacity var(--timing-sm),
      filter var(--timing-sm);

    @media (max-width: 1280px) {
      width: fit-content;
      gap: 0.5rem;
    }

    &:hover,
    &:focus {
      img {
        outline: 2px solid var(--color);
      }

      .project-name {
        text-decoration: underline;

        &::before,
        &::after {
          color: var(--color);
        }
        &::before {
          content: "[";
          transform: translateX(-0.3rem);
        }
        &::after {
          content: "]";
          transform: translateX(0.3rem);
        }
      }
    }
  }

  .project-name {
    width: fit-content;
    text-align: center;
    height: 2.5ch;

    &::before,
    &::after {
      content: "";
      display: inline-flex;
      width: 1ch;
      color: var(--bg-alter);
      transition: transform var(--timing-md);
    }

    &:before {
      transform: translateX(-0.1rem);
    }
    &:after {
      transform: translateX(0.1rem);
    }
  }

  img {
    aspect-ratio: 1;
    height: auto;
    object-fit: cover;
    border-top-left-radius: 2ch;
    border-bottom-right-radius: 2ch;
    transition: border-radius var(--timing-md);
  }

  .discrete {
    opacity: 0.3;
    filter: grayscale(1);
  }
</style>
