---
import type { Project } from "@models/Project";
import { getImage } from "@utils/images";
import { Image } from "astro:assets";

export interface Props {
  project: Project;
}

const { project } = Astro.props;
const url = "/projects/";
const image = await getImage(project.name);
---

<a class="project" id={project.name} href={url + project.name}>
  <Image src={image.default} alt=`${project.name} cover` loading="eager" />
  <p class="project-name">{project.name}</p>
</a>

<style scoped>
  .project {
    position: relative;
    display: flex;
    flex-flow: column;
    gap: 0;
    height: fit-content;
    outline: none;
    width: 15ch;
    background-color: transparent;

    @media (max-width: 1280px) {
      width: fit-content;
      gap: 0.5rem;
      img {
        width: 24ch;
        height: 24ch;
      }
    }

    &:hover,
    &:focus {
      img {
        /* border-radius: 0; */
        outline: 2px solid var(--color);
        /* border-bottom-left-radius: 2ch;
        border-top-right-radius: 2ch; */
      }

      .project-name {
        text-decoration: underline;

        &::before,
        &::after {
          color: var(--color);
        }
        &::before {
          content: "[";
          transform: translateX(-0.3rem);
        }
        &::after {
          content: "]";
          transform: translateX(0.3rem);
        }
      }
    }
  }

  .project-name {
    width: fit-content;
    text-align: center;
    height: 2.5ch;

    &::before,
    &::after {
      content: "";
      display: inline-flex;
      width: 1ch;
      color: var(--bg-darker);
      transition: transform 0.125s ease-out;
    }

    &:before {
      transform: translateX(-0.1rem);
    }
    &:after {
      transform: translateX(0.1rem);
    }
  }

  img {
    aspect-ratio: 1;
    width: 15ch;
    height: 15ch;
    object-fit: cover;
    border-top-left-radius: 2ch;
    border-bottom-right-radius: 2ch;
    outline: 2px solid transparent;
    transition:
      border-radius 0.125s ease-out,
      outline 0.125s ease-out;
  }
</style>
