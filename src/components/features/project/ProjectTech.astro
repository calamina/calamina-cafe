---
import type { Project } from "@models/Project";

interface Props {
    tech: Project["tech"];
}
const { tech } = Astro.props;

const categs = tech
    ? Object.entries(tech)?.filter((entry) => entry[0] !== "colors")
    : [];
---

<div class="tech">
    {
        categs.map((category) => (
            <div class="category">
                <slot />
                <p class="category-title">{category[0]}</p>
                <div class="taggroup">
                    {category[1].map((entry) => (
                        <span class="tag" class:list={category[0]}>
                            {entry}
                        </span>
                    ))}
                </div>
            </div>
        ))
    }
</div>

<style>
    .category {
        display: flex;
        align-items: baseline;
        padding-top: 0.25rem;
        padding-bottom: 0.5rem;
        transition: padding-left 0.2s;

        &:not(:last-of-type) {
            border-bottom: 1px solid var(--bg-darker);
        }

        &:hover {
            padding-left: 0.25rem;
        }
    }

    .category-title {
        text-transform: capitalize;
        width: 12ch;
    }

    .taggroup {
        display: flex;
        flex-flow: wrap;
        padding-top: 0.25rem;
        gap: 0.5rem;
        overflow: hidden;
    }

    .tag {
        background-color: var(--bg-darker);
        padding: 0 0.5rem;
        border-radius: 0.5rem;
        color: var(--color-hover);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-weight: 300;
    }

    html.dark .tag {
        color: var(--bg-darker);
    }

    .tools {
        background-color: hsl(50, 50%, 77%);
        background-color: #e2d8a7;
    }

    .languages {
        background-color: hsl(144, 50%, 77%);
        background-color: #a7e2be;
    }

    .colors {
        background-color: hsl(216, 50%, 77%);
        background-color: #a7bee2;
    }

    .fonts {
        background-color: hsl(288, 50%, 77%);
        background-color: #d6a7e2;
    }

    .icons {
        background-color: hsl(2, 50%, 77%);
        background-color: #e2a9a7;
    }

    .tools {
        background-color: hsl(50, 50%, 77%);
        background-color: #e2d8a7;
    }
</style>
