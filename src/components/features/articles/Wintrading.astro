---
interface Props {
  chars: string[];
}

const { chars } = Astro.props;
---

<div class="wrapper">
  {
    chars && (
      <div class="test">
        {chars.map((elt, index) => (
          <span class={"delay" + index}>{elt}</span>
        ))}
        {chars.map((elt, index) => (
          <span class={"delay" + index}>{elt}</span>
        ))}
        {chars.map((elt, index) => (
          <span class={"delay" + index}>{elt}</span>
        ))}
        {chars.map((elt, index) => (
          <span class={"delay" + index}>{elt}</span>
        ))}
        {chars.map((elt, index) => (
          <span class={"delay" + index}>{elt}</span>
        ))}
        {chars.map((elt, index) => (
          <span class={"delay" + index}>{elt}</span>
        ))}
        {chars.map((elt, index) => (
          <span class={"delay" + index}>{elt}</span>
        ))}
        {chars.map((elt, index) => (
          <span class={"delay" + index}>{elt}</span>
        ))}
        {chars.map((elt, index) => (
          <span class={"delay" + index}>{elt}</span>
        ))}
        {chars.map((elt, index) => (
          <span class={"delay" + index}>{elt}</span>
        ))}
      </div>
    )
  }
  <slot />
</div>

<style>
  .wrapper {
    display: flex;
    flex-flow: column;
    border-radius: var(--radius-sm);
    overflow: hidden;

    &:hover {
      span {
        animation-play-state: running;
        /* color: var(--highlight); */
      }
      .test {
        /* background-color: var(--highlight); */
      }
    }
  }

  .test {
    background-color: var(--bg-alter);
    width: 100%;
    height: 3rem;
    /* width: 8ch; */
    height: 5ch;
    aspect-ratio: 1;
    gap: 0.5ch;
    padding: 0 1ch;
    /* border-radius: var(--radius-sm); */
    overflow-x: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color var(--timing-md);
  }

  .delay1 {
    opacity: 0.1;
    animation-delay: 0.1s;
  }
  .delay2 {
    opacity: 0.5;
    animation-delay: 0.05s;
  }
  .delay3 {
    opacity: 1;
    animation-delay: 0.15s;
  }
  .delay4 {
    opacity: 0.3;
    animation-delay: 0.025s;
  }
  .delay5 {
    opacity: 0.7;
    animation-delay: 0.075s;
  }
  .delay6 {
    opacity: 0.2;
    animation-delay: 0.125s;
  }

  span {
    opacity: 0;
    animation: fade 2s infinite;
    color: var(--bg);
    animation-play-state: paused;
  }

  @keyframes fade {
    0% {
      opacity: 0;
    }
    10% {
      opacity: 0.5;
    }
    20% {
      opacity: 0.2;
    }
    30% {
      opacity: 1;
    }
    40% {
      opacity: 0.4;
    }
    50% {
      opacity: 0.7;
    }
    60% {
      opacity: 0.5;
    }
    70% {
      opacity: 1;
    }
    80% {
      opacity: 0.3;
    }
    90% {
      opacity: 0.5;
    }
    100% {
      opacity: 0;
    }
  }
</style>
