---
import type { Article } from "@models/Article";
interface Props {
  articles: Article[];
  url?: string;
}

const { articles, url = "articles" } = Astro.props;
---

<div>
  {
    articles.map((article) => (
      <a id={article.name} href={`/${url}/${article.name}`}>
        {article.title}
      </a>
    ))
  }
</div>

<style>
  div {
    display: flex;
    flex-flow: column;
    gap: 1rem;
    padding: 4rem 4rem 8rem;
    width: 70vw;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    /* grid-template-columns: 1fr 1fr; */

    @media (max-width: 1280px) {
      padding: 2rem;
      width: 100%;
      grid-template-columns: 1fr;
    }
  }

  a {
    width: 100%;
    padding: 0.75rem;
    text-transform: capitalize;
    outline: 2px solid var(--bg-darker);
    transition: padding-left 0.125s ease-out;
    &:after {
      content: "->";
      color: transparent;
      transform: translateX(-0.25rem);
      transition:
        transform 0.125s ease-out,
        color 0.125s ease-out;
    }

    &:hover,
    &:focus-visible {
      background-color: transparent;
      outline: 2px solid var(--color);
      padding-left: 1.25rem;

      &:after {
        content: "->";
        color: var(--color);
        transform: translateX(0);
      }
    }
  }
</style>
