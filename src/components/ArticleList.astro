---
import type { Article } from "@models/Article";
import BracketWrapper from "./BracketWrapper.astro";
interface Props {
  articles: Article[];
  url?: string;
}

const { articles, url = "articles" } = Astro.props;
---

<div>
  {
    articles.map((article) => (
      <a id={article.name} href={`/${url}/${article.name}`}>
        <BracketWrapper>
          <p>{article.name}</p>
        </BracketWrapper>
      </a>
    ))
  }
</div>

<style>
  div {
    display: flex;
    flex-flow: column;
    gap: 1rem;
    height: 50dvh;
  }

  a {
    width: 100%;
    &:hover {
      background-color: transparent;
    }
  }

  p {
    width: 100%;
    height: 3rem;
    display: grid;
    place-items: center start;
    padding: 0 2rem;
    text-transform: capitalize;
  }
</style>
