---
import { getCollection } from "astro:content";
import BracketWrapper from "./BracketWrapper.astro";
const articles = await getCollection("articles");
---

<div>
  {
    articles.map((article) => (
      <a href={`/articles/${article.id}`}>
        <BracketWrapper>
          <p>{article.id}</p>
        </BracketWrapper>
      </a>
    ))
  }
</div>

<style>
  div {
    display: flex;
    flex-flow: column;
    gap: 1rem;
    height: 50dvh;
  }

  a {
    width: 100%;
    &:hover {
      background-color: transparent;
    }
  }

  p {
    width: 100%;
    height: 3rem;
    display: grid;
    place-items: center start;
    padding: 0 2rem;
    text-transform: capitalize;
  }
</style>
