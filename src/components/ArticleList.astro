---
import ArticlePreview from "@components/ArticlePreview.astro";
import type { Article } from "@models/Article";

interface Props {
  entries: Article[];
  url?: string;
  listTitle?: string;
}

const { entries, url, listTitle = null } = Astro.props;

const chars: Record<string, string> = {
  animation: "@",
  wintrading: "$",
  shadow: "?",
};
---

<div class="list">
  {
    listTitle && (
      <div class="title">
        <h2>{listTitle}</h2>
        <span class="limit" inert />
        <p class="entries">
          <span inert>(</span>
          {entries.length} entr{entries.length > 1 ? "ies" : "y"}
          <span inert>)</span>
        </p>
      </div>
    )
  }
  {
    entries.map((entry) => (
      <ArticlePreview
        char={chars[entry.name]}
        entry={entry}
        url={`/${url}/${entry.name}`}
      />
    ))
  }
</div>

<style>
  .list {
    display: flex;
    flex-flow: column;
    gap: 1rem;
  }

  .title {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    justify-content: space-between;
  }

  .limit {
    height: 100%;
    border-bottom: 2px solid var(--bg-alter);
    display: flex;
    flex: 1;
  }

  .entries,
  .entries span {
    color: var(--color-alter);
  }

  nav {
    padding-top: 1rem;
    display: flex;
    gap: 1rem;
  }
</style>
