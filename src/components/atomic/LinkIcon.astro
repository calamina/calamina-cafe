---
import Icon from "@components/icons/Icon.astro";

interface Props {
  url: string;
  label?: string;
  icon?: string;
  online?: boolean;
}

const { url, label, online = undefined, icon } = Astro.props;

const disabled = online === undefined ? false : !online;
---

<template>
  {
    disabled ? (
      <p inert class="disabled">
        offline (for now!)
        <Icon icon="IconLinkBroken" />
      </p>
    ) : (
      <a v-if="!disabled" href={url} target="_blank">
        {label ?? "visit"}
        <Icon icon="IconLink" />
      </a>
    )
  }
</template>

<style>
  a,
  p {
    display: flex;
    align-content: center;
    border-radius: 0.5rem;
    gap: 0.5rem;
    align-items: center;
    width: fit-content;
    padding: 0.25rem 0.5rem 0.15rem;
    background-color: var(--bg-darker0);
    opacity: 1;
    transform: translateX(0);
    transition:
      opacity 0.3s 0.05s,
      transform 0.3s 0.05s;

    &:hover {
      background-color: var(--highlight);
    }

    &.disabled {
      color: var(--color-light);
      opacity: 0.8;

      svg {
        opacity: 0.3;
      }
    }
  }

  html.dark a:hover {
    background-color: var(--bg-darker0);
    color: var(--highlight);
  }
</style>
