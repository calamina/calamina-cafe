---
interface Props {
  char: string;
}

const { char } = Astro.props;
const chars: string[] = Array(6).fill(char);
const reps: string[] = Array(12).fill("");
---

<div class="deco">
  {
    reps.map(() =>
      chars.map((elt, index) => <span class={"delay" + index}>{elt}</span>),
    )
  }
</div>

<style>
  .deco {
    width: 15ch;
    display: flex;
    gap: 0.25ch;
    overflow-x: hidden;
  }

  .delay1 {
    opacity: 0.1;
    animation-delay: 0.1s;
  }
  .delay2 {
    opacity: 0.5;
    animation-delay: 0.05s;
  }
  .delay3 {
    opacity: 1;
    animation-delay: 0.15s;
  }
  .delay4 {
    opacity: 0.3;
    animation-delay: 0.025s;
  }
  .delay5 {
    opacity: 0.7;
    animation-delay: 0.075s;
  }
  .delay6 {
    opacity: 0.2;
    animation-delay: 0.125s;
  }

  span {
    opacity: 0;
    animation: fade 2s infinite;
    color: var(--bg-alter);
    animation-play-state: paused;
  }

  @keyframes fade {
    0% {
      opacity: 0;
    }
    10% {
      opacity: 0.5;
    }
    20% {
      opacity: 0.2;
    }
    30% {
      opacity: 1;
    }
    40% {
      opacity: 0.4;
    }
    50% {
      opacity: 0.7;
    }
    60% {
      opacity: 0.5;
    }
    70% {
      opacity: 1;
    }
    80% {
      opacity: 0.3;
    }
    90% {
      opacity: 0.5;
    }
    100% {
      opacity: 0;
    }
  }
</style>
