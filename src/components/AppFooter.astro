---
import Ascii from "@components/ascii.astro";
import LinkContact from "@components/atomic/LinkContact.astro";
import SocialsList from "@components/SocialsList.astro";
---

<footer>
    <div class="info">
        <div class="thanks">
            <p>Thanks</p>
            <p>for</p>
            <p>visiting <span></span></p>
        </div>
        <div class="rights">
            <a target="_blank" href="https://github.com/calamina">calamina</a>
            <span>~ {new Date().getFullYear()}</span>
        </div>
    </div>
    <div class="center">
        <Ascii class="ascii" />
        <LinkContact class="contact" />
    </div>
    <SocialsList class="socials" />
</footer>

<style scoped>
    footer {
        max-width: var(--app-width);
        background-color: var(--bg-darker0);
        width: 100%;
        display: grid;
        grid-template-columns: 18ch 1fr 18ch;
        padding: 2rem 4rem;
        gap: 2rem;
        align-items: end;
    }

    .thanks {
        justify-self: end;

        p {
            line-height: 1.25rem;
            grid-column: 2;
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }

        span {
            background-color: var(--highlight);
            height: 0.45rem;
            width: 0.45rem;
            flex-shrink: 0;
            border-radius: 0.5rem;
        }
    }

    .center {
        height: 100%;
        justify-content: space-between;
    }

    .contact {
        width: fit-content;
        justify-self: center;
    }

    .socials {
        width: fit-content;
        justify-self: center;
        justify-self: end;
    }

    .ascii {
        grid-column: 2 / 3;
        align-self: start;
        justify-self: center;
        height: 100%;
    }

    .info {
        height: 100%;
        display: flex;
        flex-flow: column;
        justify-content: space-between;
    }

    .rights {
        display: flex;
        gap: 1ch;
        align-items: center;

        & a {
            text-decoration: underline;
        }
    }

    @media (max-width: 1500px) {
        footer {
            gap: 0.5rem;
        }

        .ascii {
            font-size: 0.75vw;
        }
    }

    @media (max-width: 1280px) {
        footer {
            display: flex;
            flex-flow: column;
            align-items: center;
            padding: 3rem 1rem;
        }

        .info {
            gap: 0.5rem;
            align-items: center;
        }

        .thanks {
            display: flex;
            gap: 1ch;

            p {
                width: fit-content;
            }
        }

        .center {
            gap: 1rem;
            padding: 1rem;
        }

        .ascii {
            font-size: 1vw;
            line-height: 1vw;
            align-items: center;
            justify-content: center;
        }
    }
</style>
