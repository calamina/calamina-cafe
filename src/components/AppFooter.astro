---
import Ascii from "@components/ascii.astro";
import LinkContact from "@components/atomic/LinkContact.astro";
import SocialsList from "@components/SocialsList.astro";

const path = Astro.originPathname;
console.debug(path);
// TODO : split path and display breadcrumbs ?
---

<footer>
    <div class="main">
        <div class="info">
            <div class="thanks">
                <p>Thanks</p>
                <p>for</p>
                <p>visiting <span></span></p>
            </div>
            <div class="rights">
                <a target="_blank" href="https://github.com/calamina"
                    >calamina</a
                >
                <span>~ {new Date().getFullYear()}</span>
            </div>
        </div>
        <div class="center">
            <Ascii />
            <LinkContact />
        </div>
        <SocialsList />
    </div>
    <div class="sub">
        <div class="ariane">
            <p>You are here :</p>
            <a href="#">{path}</a>
        </div>
        <nav>
            <a href="/accessibility">accessibility</a>
            <a href="/privacy">privacy</a>
        </nav>
    </div>
</footer>

<style scoped>
    footer {
        /* max-width: var(--app-width); */
        width: 100%;
    }

    .main {
        padding: 2rem 4rem;
        background-color: var(--bg-darker0);
        display: grid;
        grid-template-columns: 18ch 1fr 18ch;
        gap: 2rem;
        align-items: end;
    }

    .sub {
        border-top: 1px solid var(--bg-darker);
        /* background-color: var(--bg-darker); */
        /* background-color: var(--bg); */
        background-color: var(--bg-darker0);
        height: 4rem;

        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 4rem;

        a {
            position: relative;
            width: fit-content;

            &::before {
                content: "";
                position: absolute;
                left: -1rem;
                background-color: var(--highlight);
                height: 0.45rem;
                width: 0.45rem;
                flex-shrink: 0;
                border-radius: 0.5rem;
            }
        }
    }

    .ariane,
    nav {
        display: flex;
        gap: 3rem;
    }

    .thanks {
        justify-self: end;

        p {
            line-height: 1.25rem;
            grid-column: 2;
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }

        span {
            background-color: var(--highlight);
            height: 0.45rem;
            width: 0.45rem;
            flex-shrink: 0;
            border-radius: 0.5rem;
        }
    }

    .center {
        height: 100%;
        justify-content: space-between;
        overflow: hidden;
    }

    .info {
        height: 100%;
        display: flex;
        flex-flow: column;
        justify-content: space-between;
    }

    .rights {
        display: flex;
        gap: 1ch;
        align-items: center;

        & a {
            text-decoration: underline;
        }
    }

    @media (max-width: 1500px) {
        footer {
            gap: 0.5rem;
        }

        .ascii {
            font-size: 0.75vw;
        }
    }

    @media (max-width: 1280px) {
        .main {
            display: flex;
            flex-flow: column;
            align-items: center;
            padding: 3rem 1rem;
        }

        .sub {
            flex-flow: column;
            align-items: center;
            padding: 1rem;
            height: auto;
            gap: 1rem;
        }

        .info {
            gap: 0.5rem;
            align-items: center;
        }

        .thanks {
            display: flex;
            gap: 1ch;

            p {
                width: fit-content;
            }
        }

        .center {
            gap: 1rem;
            padding: 1rem;
        }

        .ascii {
            font-size: 1vw;
            line-height: 1vw;
            align-items: center;
            justify-content: center;
        }
    }
</style>
