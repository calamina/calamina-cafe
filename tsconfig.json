{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "jsx": "preserve",
    "baseUrl": "src",
    "paths": {
      "@components/*": ["./components/*"],
      "@models/*": ["./models/*"],
      "@layouts/*": ["./layouts/*"],
      "@utils/*": ["./utils/*"],
    },
  }
}